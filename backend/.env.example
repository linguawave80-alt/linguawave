# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── PostgreSQL (Prisma / Neon) ───────────────────────────────────────────────
DATABASE_URL="postgresql://<user>:<password>@<host>/<dbname>?sslmode=require"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_long_random_string

# ─── AI APIs ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here   # optional

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Local dev callback:
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback
# Production (Render) — change to your actual Render backend URL:
# GOOGLE_CALLBACK_URL=https://linguawave-backend-qk64.onrender.com/api/v1/auth/google/callback

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (for production)
# In dev, all localhost ports are automatically allowed.
# Example for Render:
# ALLOWED_ORIGINS=https://linguawave-frontend.onrender.com
ALLOWED_ORIGINS=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
