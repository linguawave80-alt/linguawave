{
  "info": {
    "name": "LinguaWave API",
    "description": "Complete API test collection for LinguaWave Language Learning Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/../health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "pm.test('Has token', () => {",
                "  const json = pm.response.json();",
                "  pm.expect(json.data.accessToken).to.be.a('string');",
                "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                "  pm.collectionVariables.set('userId', json.data.user.id);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@linguawave.dev\",\n  \"username\": \"testuser123\",\n  \"password\": \"Password123!\",\n  \"nativeLanguage\": \"en\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has token', () => {",
                "  const json = pm.response.json();",
                "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@linguawave.dev\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Me",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has user', () => pm.expect(pm.response.json().data.user).to.be.an('object'));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/profile",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nativeLanguage\": \"en\",\n  \"targetLanguages\": [\"fr\", \"es\"]\n}"
            }
          }
        },
        {
          "name": "Leaderboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/leaderboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Speech",
      "item": [
        {
          "name": "Analyze Pronunciation",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has accuracy', () => {",
                "  const json = pm.response.json();",
                "  pm.expect(json.data.overallAccuracy).to.be.a('number');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/speech/analyze",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetText\": \"Hello, how are you today?\",\n  \"transcribedText\": \"Hello, how are you today?\",\n  \"language\": \"en\",\n  \"sessionId\": \"test_session_001\"\n}"
            }
          }
        },
        {
          "name": "Get History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/speech/history?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Accuracy Trend (30d)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/speech/accuracy-trend?days=30",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Create Session",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language\": \"en\",\n  \"duration\": 120,\n  \"accuracy\": 85.5,\n  \"wordsAttempted\": 20,\n  \"wordsCorrect\": 17,\n  \"transcript\": \"Hello how are you today\",\n  \"feedback\": \"Good work on consonants\"\n}"
            }
          }
        },
        {
          "name": "List Sessions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/sessions?page=1&limit=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chat/messages?roomId=global",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/chat/messages",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Hello everyone! Ready to practice French today.\",\n  \"roomId\": \"global\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Languages",
      "item": [
        {
          "name": "List Languages",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/languages"
          }
        }
      ]
    }
  ]
}
